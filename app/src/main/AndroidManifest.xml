<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SchoolEvent">

        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SchoolEvent.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan"/>
        <!--
    adjustPan → layar geser ke atas saat keyboard muncul
    tapi navbar TIDAK ikut naik
    Berbeda dengan adjustResize yang mendorong semua layout
        -->

        <activity
            android:name=".activities.DetailActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AboutActivity"
            android:parentActivityName=".activities.MainActivity"/>

    </application>
</manifest>