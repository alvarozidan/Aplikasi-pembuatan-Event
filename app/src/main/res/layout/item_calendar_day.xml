<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center">

    <!--
        Background bulat saat tanggal dipilih
        Diatur via kode Java
    -->
    <TextView
        android:id="@+id/tv_day"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textSize="14sp"/>

    <!--
        Dot kecil → muncul jika tanggal punya event
        Defaultnya gone, ditampilkan via kode Java
    -->
    <View
        android:id="@+id/view_dot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_event_dot"
        android:visibility="gone"/>

</LinearLayout>