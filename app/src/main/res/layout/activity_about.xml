<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo & Nama App -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitCenter"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smakanza Event"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:fontFamily="@font/poppins_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Versi 1.0.0"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Section: Tentang -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tentang Aplikasi"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Smakanza Event adalah aplikasi resmi untuk menampilkan informasi seputar kegiatan dan event yang akan berlangsung di SMK Negeri 1 Wonosobo (Smakanza). Dibuat untuk memudahkan seluruh warga sekolah agar tidak ketinggalan satu pun momen penting."
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="24dp"/>

        <!-- Section: Fitur -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fitur Utama"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="12dp"/>

        <!-- Fitur 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="18sp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informasi Event Terkini"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semua event sekolah tampil secara real-time — mulai dari lomba, seminar, ekstrakurikuler, hingga acara sekolah lainnya."
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Fitur 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="💬"
                android:textSize="18sp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Komentar &amp; Diskusi"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Setiap siswa dapat meninggalkan komentar pada tiap event untuk berdiskusi, bertanya, atau berbagi antusiasme bersama teman-teman."
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Fitur 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="❤️"
                android:textSize="18sp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Like Event Favorit"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tandai event yang paling ditunggu-tunggu dengan fitur like. Semakin banyak like, semakin besar semangat bersama!"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Fitur 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="💡"
                android:textSize="18sp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usulan dari Siswa"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Punya ide event yang keren? Kirim usulan langsung lewat aplikasi! Setiap suara siswa akan diterima dan ditinjau oleh pihak sekolah."
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="24dp"/>

        <!-- Section: Dikembangkan oleh -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dikembangkan Oleh Alvaro Zidane"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aplikasi ini dikembangkan oleh siswa Program Keahlian Rekayasa Perangkat Lunak (RPL) SMK Karya Nasional Zanafa sebagai bentuk kontribusi nyata teknologi untuk kemajuan sekolah."
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"/>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2025 Smakanza · Dibuat dengan ❤️ oleh siswa RPL Smakanza"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"
            android:paddingBottom="16dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>