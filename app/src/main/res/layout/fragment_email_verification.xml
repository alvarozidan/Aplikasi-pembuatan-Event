<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Icon email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📧"
            android:textSize="72sp"
            android:layout_marginBottom="24dp"/>

        <!-- Judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verifikasi Email"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Deskripsi -->
        <TextView
            android:id="@+id/tv_verify_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="32dp"
            android:text="Kami telah mengirim link verifikasi ke\nemail@example.com\n\nSilakan cek inbox atau folder spam kamu"/>

        <!-- Card status -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_verify_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳ Menunggu verifikasi..."
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="8dp"/>

                <!-- Progress bar cek otomatis -->
                <ProgressBar
                    android:id="@+id/progress_verify"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="0"
                    android:max="30"
                    android:progressTint="?attr/colorPrimary"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tv_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cek otomatis dalam 30 detik"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Tombol cek manual -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_check_verification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Saya sudah verifikasi"
            android:padding="14dp"
            android:textSize="15sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- Tombol kirim ulang -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_resend_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📨 Kirim Ulang Email"
            android:padding="14dp"
            android:textSize="15sp"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="12dp"/>

        <!-- Tombol ganti email / kembali -->
        <TextView
            android:id="@+id/tv_back_to_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gunakan email lain"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:padding="8dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>