<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SchoolEvent" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="NavTextActive">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <style name="NavTextInactive">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <!-- Tambahkan ini sebelum tag </resources> penutup -->
    <style name="Theme.SchoolEvent.Splash" parent="Base.Theme.SchoolEvent">
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <!-- Tema utama → mewarisi Base.Theme.SchoolEvent -->
    <!-- Semua konfigurasi diwarisi dari Base theme di atas -->
    <style name="Theme.SchoolEvent" parent="Base.Theme.SchoolEvent" />
</resources>